DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=house_points
DB_USER=house_points
DB_PASS=change-me
DB_ROOT_PASS=root-change-me
# firebase/php-jwt 7.x enforces a minimum HMAC key length for HS256 (32+ bytes recommended)
# generate one with: openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-bytes-long
JWT_TTL=900
APP_DEBUG=true
# Comma-separated list of allowed browser origins for the web client, or * for any.
# e.g. CORS_ALLOWED_ORIGINS=http://localhost:8081,https://houses.example.com
CORS_ALLOWED_ORIGINS=*
# Used by CommentGenerator to auto-write a comment for every point event.
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=change-me
